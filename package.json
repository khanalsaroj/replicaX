{
  "name": "@iamsaroj/replicax",
  "version": "0.0.3",
  "description": "Copy the setup, not the code. Extract a project's tooling, structure, and conventions and recreate them in new projects.",
  "type": "module",
  "license": "MIT",
  "author": "Saroj Khanal <imsaroj@g.skku.edu> (https://github.com/khanalsaroj)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khanalsaroj/replicaX.git"
  },
  "bugs": {
    "url": "https://github.com/khanalsaroj/replicaX/issues"
  },
  "homepage": "https://github.com/khanalsaroj/replicaX#readme",
  "keywords": [
    "cli",
    "scaffold",
    "boilerplate",
    "tooling",
    "configuration",
    "project-setup",
    "developer-tools"
  ],
  "bin": {
    "replicax": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "ignore": "^7.0.5",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "tar": "^7.5.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
